RewriteEngine On

# Redirect index.html requests to the trailing slash /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*index\.html\ HTTP/
RewriteRule ^(.*)index\.html$ $1 [R=301,L]

# Redirect any other explicit "page.html" request to the extension-less URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteCond %{THE_REQUEST} !index\.html
RewriteRule ^(.*)\.html$ $1 [R=301,L]

# Internally serve page.html when /page is requested, without changing the URL.
# Uses mod_negotiation's MultiViews instead of a hand-rolled RewriteRule:
# a custom "$1.html" rewrite with [L] restarts the whole ruleset against its
# own output in per-directory context, and on this host that was looping
# until the internal-redirect limit tripped (500). MultiViews has no such
# loop risk — it's a one-line, purpose-built mechanism for exactly this.
Options +MultiViews
